# ─────────────────────────────────────────────
#  FlipForge — Environment Configuration
# ─────────────────────────────────────────────

# ── DEMO MODE ─────────────────────────────────
# Set to "true" to run without any API keys.
# All eBay and pricing calls will use mock data.
# Perfect for learning, testing, and development.
DEMO_MODE=true

# ── eBay API (leave blank in demo mode) ───────
# Get credentials at: https://developer.ebay.com
# → My Account → Application Keys → Get a Free Key Set
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=http://localhost:8000/ebay/callback

# ── eBay Environment ──────────────────────────
# "sandbox"    → test environment, no real listings
# "production" → live eBay, real listings
EBAY_ENV=sandbox

# ── Anthropic Claude AI (optional) ───────────
# Get key at: https://console.anthropic.com → API Keys
# Leave blank to use the built-in rule-based generator.
ANTHROPIC_API_KEY=

# ── Pricing ───────────────────────────────────
DEFAULT_MARKUP=0.80
MARKET_PRICE_THRESHOLD=0.20

# ── Server ────────────────────────────────────
HOST=0.0.0.0
PORT=8000
